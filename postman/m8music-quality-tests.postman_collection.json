              "    pm.expect(jsonData.nome).to.eql(\"Rafael Lima\");\r",
              "});\r",
              "\r",
              "pm.test(\"Gênero musical deve ser Samba\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.generoMusical).to.eql(\"Samba\");\r",
              "});\r",
              "\r",
              "pm.test(\"Email do músico deve ser rafael@mmusic.com\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.email).to.eql(\"rafael@mmusic.com\");\r",
              "});"
            ],
