  "item": [
    {
      "name": "TA01 - Cadastrar músico",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code deve ser 200 ou 201\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
              "});\r",
              "\r",
              "pm.test(\"Resposta deve estar em JSON\", function () {\r",
              "    pm.response.to.be.json;\r",
              "});\r",
              "\r",
              "pm.test(\"Resposta deve conter ID do músico\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData).to.have.property(\"id\");\r",
              "    pm.collectionVariables.set(\"musicoId\", jsonData.id);\r",
              "});\r",
              "\r",
              "pm.test(\"Nome do músico deve estar correto\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.nome).to.eql(\"Rafael Lima\");\r",
              "});\r",
              "\r",
              "pm.test(\"Gênero musical deve estar correto\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.generoMusical).to.eql(\"Samba\");\r",
              "});\r",
              "\r",
              "pm.test(\"Email do músico deve estar correto\", function () {\r",
              "    const jsonData = pm.response.json();\r",
              "    pm.expect(jsonData.email).to.eql(\"rafael@mmusic.com\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"nome\": \"Rafael Lima\",\r\n  \"generoMusical\": \"Samba\",\r\n  \"email\": \"rafael@mmusic.com\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/musicos",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "musicos"
          ]
        }
      },
      "response": []
    },
